{
  "name": "opencode-snip",
  "description": "OpenCode plugin that prefixes shell commands with snip to reduce LLM token consumption",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint ."
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.8",
    "@vitest/eslint-plugin": "^1.6.19",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "snip",
    "llm",
    "tokens",
    "cli"
  ],
  "license": "MIT",
  "homepage": "https://github.com/VincentHardouin/opencode-snip",
  "repository": {
    "type": "git",
    "url": "https://github.com/VincentHardouin/opencode-snip"
  },
  "engines": {
    "node": "^24"
  },
  "files": [
    ".opencode/plugins",
    "dist"
  ],
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/npm",
      "@semantic-release/github"
    ]
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  }
}
